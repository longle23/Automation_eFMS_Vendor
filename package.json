{
  "name": "automation-efms-vendor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:onedrive": "npm run build && node dist/check-onedrive.js",
    "dev": "tsx watch src/index.ts",
    "once": "npm run build && node dist/index.js --once",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.2.1",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
